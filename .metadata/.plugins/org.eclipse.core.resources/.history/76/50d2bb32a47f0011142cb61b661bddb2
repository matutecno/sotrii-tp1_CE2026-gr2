/**
 * @brief Returns the latest sample stored by the DMA.
 */
uint16_t adc_get_dma_sample(void)
{
	return adc_dma_buffer;
}

/**
 * @brief Sends a sample from an ISR to the Driver Input Queue.
 */
BaseType_t adc_input_push_from_isr(
        uint16_t sample,
        BaseType_t *pxHigherPriorityTaskWoken)
{
    BaseType_t ret;

    ret = xQueueOverwriteFromISR(
            adc_device.input_queue,
            &sample,
            pxHigherPriorityTaskWoken);

    return ret;
}

/* Interface functions */

void open_adc(ADC_HandleTypeDef *h_adc_device)
{
	/* Save ADC Handle */
	adc_device.hadc = h_adc_device;

	/* Device Information */
	adc_device.device_id = ADC_DEVICE_ID;
	adc_device.opened = true;

	/* Create Input Queue */
	adc_device.input_queue = xQueueCreate(
	        ADC_INPUT_QUEUE_LENGTH,
	        sizeof(uint16_t));

	if (adc_device.input_queue == NULL)
	{
	    LOGGER_INFO("Error creating ADC Input Queue");
	    return;
	}

	/* Create Output Queue */
	adc_device.output_queue = xQueueCreate(
	        ADC_OUTPUT_QUEUE_LENGTH,
	        sizeof(uint16_t));

	if (adc_device.output_queue == NULL)
	{
	    LOGGER_INFO("Error creating ADC Output Queue");

	    vQueueDelete(adc_device.input_queue);

	    return;
	}

	/* Create Gatekeeper Task */
	BaseType_t ret;

	ret = xTaskCreate(
	        task_adc_rx,
	        TASK_ADC_RX_NAME,
	        TASK_ADC_RX_STACK_SIZE,
	        NULL,
	        TASK_ADC_RX_PRIORITY,
	        &adc_device.task_rx);

	if (ret != pdPASS)
	{
	    LOGGER_INFO("Error creating ADC Gatekeeper Task");

	    vQueueDelete(adc_device.input_queue);
	    vQueueDelete(adc_device.output_queue);

	    return;
	}
	else{LOGGER_INFO("ADC Gatekeeper Task");}

	/* Start ADC using DMA */
	if (HAL_ADC_Start_DMA(
	        adc_device.hadc,
	        (uint32_t *)&adc_dma_buffer,
	        1) != HAL_OK)
	{
	    LOGGER_INFO("Error starting ADC DMA");

	    vTaskDelete(adc_device.task_rx);

	    vQueueDelete(adc_device.input_queue);
	    vQueueDelete(adc_device.output_queue);

	    return;
	}
}

void release_adc(ADC_HandleTypeDef *h_adc_device)
{
	UNUSED(h_adc_device);

	/* Stop ADC DMA */
	HAL_ADC_Stop_DMA(adc_device.hadc);

	/* Delete Gatekeeper Task */
	if (adc_device.task_rx != NULL)
	{
		vTaskDelete(adc_device.task_rx);
	}

	/* Delete Queues */
	if (adc_device.input_queue != NULL)
	{
		vQueueDelete(adc_device.input_queue);
	}

	if (adc_device.output_queue != NULL)
	{
		vQueueDelete(adc_device.output_queue);
	}

	/* Reset Driver */
	adc_device.hadc = NULL;
	adc_device.task_rx = NULL;
	adc_device.input_queue = NULL;
	adc_device.output_queue = NULL;
	adc_device.opened = false;
}

