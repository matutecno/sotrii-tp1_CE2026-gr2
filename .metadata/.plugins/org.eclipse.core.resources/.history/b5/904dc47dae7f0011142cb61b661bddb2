#ifndef TASK_ADC_INTERFACE_H_
#define TASK_ADC_INTERFACE_H_

/********************** CPP guard ********************************************/
#ifdef __cplusplus
extern "C" {
#endif

/********************** inclusions *******************************************/
#include <stdbool.h>

#include "FreeRTOS.h"
#include "task.h"
#include "queue.h"

#include "main.h"

/********************** macros ***********************************************/
#define ADC_DEVICE_ID              (0U)

#define ADC_INPUT_QUEUE_LENGTH     (1U)
#define ADC_OUTPUT_QUEUE_LENGTH    (1U)

/********************** typedef **********************************************/

typedef struct
{
	uint32_t device_id;

	ADC_HandleTypeDef *hadc;

	/* Queue with Input Data Spooler */
	QueueHandle_t input_queue;

	/* Queue with Output Data Spooler */
	QueueHandle_t output_queue;

	/* Gatekeeper Task */
	TaskHandle_t task_rx;

	uint16_t value; //last ADC value

	bool opened;

	uint32_t overflow;

} adc_device_t;

/********************** external data declaration ****************************/
extern adc_device_t adc_device;
/********************** external functions declaration ***********************/
extern void open_adc(ADC_HandleTypeDef *h_adc_device);
extern void release_adc(ADC_HandleTypeDef *h_adc_device);

extern void write_adc(ADC_HandleTypeDef *h_adc_device);
extern uint16_t read_adc(ADC_HandleTypeDef *h_adc_device);

extern void ioctl_adc(ADC_HandleTypeDef *h_adc_device);

extern uint16_t adc_get_dma_sample(void);

extern BaseType_t adc_input_push_from_isr(uint16_t sample,
                                    BaseType_t *pxHigherPriorityTaskWoken);

/********************** End of CPP guard *************************************/
#ifdef __cplusplus
}
#endif

#endif /* TASK_ADC_INTERFACE_H_ */

/********************** end of file ******************************************/
